{
  "name": "easytools",
  "version": "0.1.0",
  "description": "Local Electron toolbox for daily utilities.",
  "author": "nfangxu",
  "main": "out/main/index.js",
  "type": "module",
  "scripts": {
    "dev": "npm run rebuild:sqlite:electron && electron-vite dev",
    "build": "npm run typecheck && npm run rebuild:sqlite:electron && electron-vite build",
    "dist": "npm run build && electron-builder --publish never",
    "dist:win": "npm run build && electron-builder --win --publish never",
    "dist:mac": "npm run build && electron-builder --mac --publish never",
    "generate:icons": "node scripts/generate-icons.mjs",
    "rebuild:sqlite:electron": "node scripts/rebuild-sqlite.mjs electron",
    "rebuild:sqlite:node": "node scripts/rebuild-sqlite.mjs node",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json",
    "test": "npm run rebuild:sqlite:node && vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "better-sqlite3": "^12.10.0",
    "electron-vite": "^3.1.0",
    "lucide-react": "^0.468.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^5.0.0",
    "electron": "^35.0.0",
    "electron-builder": "^26.8.1",
    "node-gyp": "^12.3.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vitest": "^3.0.0"
  },
  "build": {
    "appId": "com.easytools.app",
    "productName": "EasyTools",
    "icon": "build/icons/icon.png",
    "directories": {
      "output": "dist"
    },
    "files": [
      "out/**",
      "package.json"
    ],
    "extraMetadata": {
      "main": "out/main/index.js"
    },
    "npmRebuild": false,
    "win": {
      "icon": "build/icons/icon.ico",
      "target": [
        "nsis",
        "zip"
      ],
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    },
    "mac": {
      "icon": "build/icons/icon.icns",
      "target": [
        "dmg"
      ],
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    }
  }
}
