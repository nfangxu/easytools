{
  "name": "easytools",
  "version": "0.1.0",
  "description": "Local Electron toolbox for daily utilities.",
  "main": "out/main/index.js",
  "type": "module",
  "scripts": {
    "dev": "npm run rebuild:sqlite:electron && electron-vite dev",
    "build": "npm run typecheck && npm run rebuild:sqlite:electron && electron-vite build",
    "dist": "npm run build && electron-builder",
    "dist:win": "npm run build && electron-builder --win",
    "dist:mac": "npm run build && electron-builder --mac",
    "rebuild:sqlite:electron": "cd node_modules/better-sqlite3 && npm_config_runtime=electron npm_config_target=$(node -p \"require('../electron/package.json').version\") npm_config_disturl=https://electronjs.org/headers node-gyp rebuild --release",
    "rebuild:sqlite:node": "cd node_modules/better-sqlite3 && node-gyp rebuild --release",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json",
    "test": "npm run rebuild:sqlite:node && vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "better-sqlite3": "^11.10.0",
    "electron": "^35.0.0",
    "electron-vite": "^3.1.0",
    "lucide-react": "^0.468.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^5.0.0",
    "electron-builder": "^26.8.1",
    "node-gyp": "^12.3.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vitest": "^3.0.0"
  },
  "build": {
    "appId": "com.easytools.app",
    "productName": "EasyTools",
    "directories": {
      "output": "dist"
    },
    "files": [
      "out/**",
      "package.json"
    ],
    "extraMetadata": {
      "main": "out/main/index.js"
    },
    "npmRebuild": false,
    "win": {
      "target": [
        "nsis",
        "zip"
      ]
    },
    "mac": {
      "target": [
        "dmg"
      ]
    }
  }
}
